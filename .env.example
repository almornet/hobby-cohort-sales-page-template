# --- Microsoft Clarity (optional) ---
# https://learn.microsoft.com/en-us/clarity/setup-and-installation/clarity-api
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id_here

# --- Meta Pixel (browser) ---
NEXT_PUBLIC_META_PIXEL_ID=your_pixel_id_here

# --- Meta Conversions API (server-side events) ---
# Same pixel ID as above, plus system user access token from Meta Business settings.
META_PIXEL_ID=your_pixel_id_here
META_ACCESS_TOKEN=your_meta_system_user_access_token
# Optional: Meta Events Manager test event code for debugging CAPI
META_TEST_EVENT_CODE=

# --- Stripe ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Redis (optional) ---
# Used for IP-based countdown persistence across browsers. If unset, countdown uses cookies only.
# e.g. Upstash: redis://default:password@host:port
REDIS_URL=
